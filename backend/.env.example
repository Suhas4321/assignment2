# Database — leave default for SQLite zero-config, or set Postgres:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/crm_hcp
DATABASE_URL=sqlite:///./crm_hcp.db

# Groq API (https://console.groq.com) — required for full LLM agent
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile

# App
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
DEFAULT_REP_ID=REP-001
